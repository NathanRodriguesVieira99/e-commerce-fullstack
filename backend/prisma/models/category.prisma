model Category {
  id          String  @id @default(uuid())
  name        String
  description String?
  slug        String  @unique
  imageUrl    String? @map("image_url")
  isActive    Boolean @default(true) @map("is_active")

  // 1:N
  products Product[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([slug])
  @@index([isActive])
  @@map("categories")
}
